{
  "appId": "com.s-market.app",
  "productName": "S-Market",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "src/main/database/schema.sql",
      "to": "database/schema.sql"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  }
}
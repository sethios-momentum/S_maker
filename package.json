{
  "name": "s-market",
  "version": "1.0.0",
  "description": "Application de gestion de commandes S-Market",
  "main": "dist/main/main.js",
  "author": "S-Market",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:main": "tsc --project tsconfig.main.json",
    "build:all": "npm run build && npm run build:main",
    "electron": "wait-on http://localhost:3000 && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron\"",
    "dist": "npm run build:all && electron-builder",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.2.0",
    "vite": "^7.3.1",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.s-market.app",
    "productName": "S-Market",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src/main/database/schema.sql",
        "to": "database/schema.sql"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
